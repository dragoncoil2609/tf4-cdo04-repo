{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3StateBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::tf4-cdo04-terraform-state-7na270jm"
    },
    {
      "Sid": "AllowS3StateObjectAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::tf4-cdo04-terraform-state-7na270jm/tf4-cdo04/sandbox/*"
    },
    {
      "Sid": "AllowKMSStateAccess",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:DescribeKey"
      ],
      "Resource": "*"
    }
  ]
}
