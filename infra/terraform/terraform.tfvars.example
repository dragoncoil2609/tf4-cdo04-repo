# -----------------------------------------------------------------------------
# CDO-04 Platform -- terraform.tfvars.example
# Vinh-owned Terraform slice only.
# -----------------------------------------------------------------------------

project_name = "tf4-cdo04"
environment  = "sandbox"
aws_region   = "us-east-1"

vpc_cidr = "10.0.0.0/16"
az_count = 2

# CPOA-46: Telemetry API task definition image.
# Replace after Telemetry API image exists.
telemetry_api_image_tag = "MOCK_PLACEHOLDER_TELEMETRY_API:latest"

# CPOA-47: Prediction Worker task definition image.
# Replace after Prediction Worker image exists.
prediction_worker_image_tag = "MOCK_PLACEHOLDER_PREDICTION_WORKER:latest"

# CPOA-48: AI Engine task definition image.
# Replace after AI Engine image exists.
ai_engine_image_tag = "MOCK_PLACEHOLDER_AI_ENGINE:latest"

# Application container port for Telemetry API and AI Engine.
app_port = 8080

# TODO (CPOA-40): ALB ingress CIDRs/security groups belong to Truong An.
# TODO (CPOA-78): deployment/certificate variables belong to Nguyen Huy Hoang.
# Note: Current scope is HTTP ALB (no HTTPS/ACM). Certificate and HTTPS listener
# wiring are deferred to team assignment scope.
# TODO (CPOA-88/CPOA-98): alert/budget variables belong to Ninh/Huy.
