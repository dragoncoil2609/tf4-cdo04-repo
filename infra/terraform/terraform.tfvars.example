project_name = "tf4-cdo04"
environment  = "sandbox"
aws_region   = "us-east-1"

vpc_cidr = "10.0.0.0/16"
az_count = 2

# CPOA-46: Telemetry API task definition image.
# Replace after Telemetry API image exists.
telemetry_api_image_tag = "MOCK_PLACEHOLDER_TELEMETRY_API:latest"

