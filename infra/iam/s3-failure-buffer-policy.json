{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowWriteFailureBuffer",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::cdo-telemetry-failure-buffer/telemetry-failures/*"
    },
    {
      "Sid": "AllowListFailureBufferForReplay",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::cdo-telemetry-failure-buffer",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "telemetry-failures/*"
          ]
        }
      }
    },
    {
      "Sid": "AllowReadDeleteFailureBufferForReplay",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::cdo-telemetry-failure-buffer/telemetry-failures/*"
    }
  ]
}
